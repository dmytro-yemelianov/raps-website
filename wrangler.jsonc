{
  "name": "raps-website",
  "main": "./src/worker.ts",
  "compatibility_date": "2026-02-17",
  "routes": [
    { "pattern": "rapscli.xyz", "custom_domain": true },
    { "pattern": "www.rapscli.xyz", "custom_domain": true },
    { "pattern": "tests.rapscli.xyz/*", "zone_name": "rapscli.xyz" }
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
    "run_worker_first": [
      "/",
      "/index.html",
      "/_vercel/insights/*",
      "/api/analytics"
    ]
  }
}
